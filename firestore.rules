rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Portfolyo resimlerini herkes görebilmeli
    match /portfolio/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Diğer her şey için kullanıcı girişi gerekir
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
